{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/api-metadata/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/api-player/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/api-cineverse/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/api-omegatech/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/_i18n/:path*", "destination": "/api/server-entrypoint" },
    { "source": "/manifest.webmanifest", "destination": "/api/server-entrypoint" },
    { "source": "/sitemap.xml", "destination": "/api/server-entrypoint" },
    { "source": "/watch", "destination": "/index.html" },
    { "source": "/trailer", "destination": "/index.html" },
    { "source": "/toplist", "destination": "/index.html" },
    { "source": "/movie/:path*", "destination": "/index.html" },
    { "source": "/tv/:path*", "destination": "/index.html" }
  ]
}
